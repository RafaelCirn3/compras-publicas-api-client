# Configurações da API
API_BASE_URL=https://apipcp.portaldecompraspublicas.com.br/publico
PUBLIC_KEY=SUA_PUBLIC_KEY_AQUI

# Configurações de Busca
UF=PB
DIAS_BUSCA=30

# Filtros
KEYWORDS=MATERIAL,ELETRICO
STATUS_ALVO=RECEBENDO PROPOSTAS

# Paginação
PAGE_SIZE=1




# ============================================================
# Bot RPA Configuration (para versão Selenium)
# ============================================================
# Unidade Federativa
UF=PB

# Número de dias para busca retroativa (apenas para API)
DIAS_BUSCA=30

# Tamanho da página de resultados
PAGE_SIZE=1

# ============================================================
# Configurações do Navegador (Selenium)
# ============================================================
# Timeout padrão para elementos (segundos)
SELENIUM_TIMEOUT=20

# Tempo de espera implícita (segundos)
SELENIUM_IMPLICITLY_WAIT=10

# ============================================================
# Configurações de Saída
# ============================================================
# Nome do arquivo de resultados
RESULTADO_ARQUIVO=processos_encontrados.txt

# Modo de exibição: console, arquivo, ambos
RESULTADO_MODO=ambos
